# ============================================================
# Biblioteca padrao Tarbalo – vetores
# ============================================================

# ---------- int[] ----------

func int[] slice1d_int(int arr[]. int ini. int fimExcl) {
    bglh int tamArr: tamanho(arr).
    sepa (ini < 0 ou ini > tamArr ou fimExcl < 0 ou fimExcl > tamArr) {
        manda("Erro: limites invalidos em slice1d_int").
        bond int arrErro[0].
        receba arrErro.
    }.
    bglh int tam: fimExcl - ini.
    sepa (tam <= 0) {
        bond int arrVazio[0].
        receba arrVazio.
    }.
    bond int res[tam].
    para (bglh int i : 0. i < tam. i : i + 1) {
        res[i] : arr[ini + i].
    }.
    receba res.
}.

func int[][] slice2d_int(int arr[][]. int ini0. int fimExcl0. int ini1. int fimExcl1) {
    bglh int lin: fimExcl0 - ini0.
    bglh int col: fimExcl1 - ini1.
    sepa (lin <= 0 ou col <= 0) {
        bond int arrVazio[0][0].
        receba arrVazio.
    }.
    bond int res[lin][col].
    para (bglh int i : 0. i < lin. i : i + 1) {
        para (bglh int j : 0. j < col. j : j + 1) {
            res[i][j] : arr[ini0 + i][ini1 + j].
        }.
    }.
    receba res.
}.

func int[] anexar_int(int arr[]. int elem) {
    bglh int tam: tamanho(arr).
    bond int novo[tam + 1].
    para (bglh int i : 0. i < tam. i : i + 1) {
        novo[i] : arr[i].
    }.
    novo[tam] : elem.
    receba novo.
}.

func int[] inserir_int(int arr[]. int pos. int elem) {
    bglh int tam: tamanho(arr).
    sepa (pos < 0 ou pos > tam) {
        manda("Erro: posicao invalida em inserir_int").
        receba arr.
    }.
    bond int novo[tam + 1].
    para (bglh int i : 0. i < pos. i : i + 1) {
        novo[i] : arr[i].
    }.
    novo[pos] : elem.
    para (bglh int i : pos. i < tam. i : i + 1) {
        novo[i + 1] : arr[i].
    }.
    receba novo.
}.

func int[] remover_int(int arr[]. int pos) {
    bglh int tam: tamanho(arr).
    sepa (pos < 0 ou pos >= tam) {
        manda("Erro: posicao invalida em remover_int").
        receba arr.
    }.
    bond int novo[tam - 1].
    para (bglh int i : 0. i < pos. i : i + 1) {
        novo[i] : arr[i].
    }.
    para (bglh int i : pos + 1. i < tam. i : i + 1) {
        novo[i - 1] : arr[i].
    }.
    receba novo.
}.

func vazio ordenar_int(int arr[]) {
    bglh int n: tamanho(arr).
    para (bglh int i : 0. i < n - 1. i : i + 1) {
        para (bglh int j : 0. j < n - i - 1. j : j + 1) {
            sepa (arr[j] > arr[j + 1]) {
                bglh int t: arr[j].
                arr[j] : arr[j + 1].
                arr[j + 1] : t.
            }.
        }.
    }.
}.

func vazio inverter_int(int arr[]) {
    bglh int n: tamanho(arr).
    para (bglh int i : 0. i < n / 2. i : i + 1) {
        bglh int t: arr[i].
        arr[i] : arr[n - 1 - i].
        arr[n - 1 - i] : t.
    }.
}.

func int[] redim_int(int arr[]. int novoTam) {
    bglh int tam: tamanho(arr).
    sepa (novoTam < 0) {
        manda("Erro: tamanho invalido em redim_int").
        receba arr.
    }.
    bond int novo[novoTam].
    bglh int lim: novoTam.
    sepa (tam < lim) { lim : tam. }.
    para (bglh int i : 0. i < lim. i : i + 1) {
        novo[i] : arr[i].
    }.
    receba novo.
}.

