bora
    # ================================================================
    # DEMONSTRACAO DE ERROS SEMANTICOS DO TARBALO
    # Cada seção contém um erro diferente que o compilador detecta.
    # O número ao lado do comentário indica a linha do erro.
    # ================================================================

    # ---------------------------------------------------------------
    # 1. VARIAVEL DUPLICADA NO MESMO ESCOPO
    # ---------------------------------------------------------------
    bglh int x : 10.
    bglh int x : 20.

    # ---------------------------------------------------------------
    # 2. VETOR DUPLICADO NO MESMO ESCOPO
    # ---------------------------------------------------------------
    bond int nums[5].
    bond int nums[3].

    # ---------------------------------------------------------------
    # 3. TIPO INCOMPATIVEL NA INICIALIZACAO
    # ---------------------------------------------------------------
    bglh int texto : "ola".

    # ---------------------------------------------------------------
    # 4. TIPO INCOMPATIVEL NA ATRIBUICAO
    # ---------------------------------------------------------------
    bglh int a : 5.
    a : "texto".

    # ---------------------------------------------------------------
    # 5. VARIAVEL NAO DECLARADA
    # ---------------------------------------------------------------
    bglh int b : variavelInexistente.

    # ---------------------------------------------------------------
    # 6. ATRIBUICAO A VARIAVEL NAO DECLARADA
    # ---------------------------------------------------------------
    variavelFantasma : 42.

    # ---------------------------------------------------------------
    # 7. ATRIBUICAO A FUNCAO (nao a variavel)
    # ---------------------------------------------------------------
    func int dobro(int n) {
        receba n * 2.
    }.
    dobro : 10.

    # ---------------------------------------------------------------
    # 8. USO DE FUNCAO VOID EM EXPRESSAO
    # ---------------------------------------------------------------
    func vazio imprima(txt msg) {
        manda(msg).
    }.
    bglh int c : imprima("teste").

    # ---------------------------------------------------------------
    # 9. FUNCAO NAO DECLARADA
    # ---------------------------------------------------------------
    bglh int d : funcaoFantasma(10).

    # ---------------------------------------------------------------
    # 10. NUMERO ERRADO DE ARGUMENTOS
    # ---------------------------------------------------------------
    bglh int errArg : dobro(1 ; 2).

    # ---------------------------------------------------------------
    # 11. TIPO DE ARGUMENTO INCOMPATIVEL
    # ---------------------------------------------------------------
    bglh int f : dobro("texto").

    # ---------------------------------------------------------------
    # 12. RETORNO INCOMPATIVEL COM TIPO DA FUNCAO
    # ---------------------------------------------------------------
    func int retornaErrado() {
        receba "texto".
    }.

    # ---------------------------------------------------------------
    # 13. RETORNO VAZIO EM FUNCAO COM TIPO
    # ---------------------------------------------------------------
    func int retornaNada() {
        receba.
    }.

    # ---------------------------------------------------------------
    # 14. RECEBA FORA DE FUNCAO
    # ---------------------------------------------------------------
    receba 42.

    # ---------------------------------------------------------------
    # 15. PARE (morreu) FORA DE LACO
    # ---------------------------------------------------------------
    morreu.

    # ---------------------------------------------------------------
    # 16. DALE FORA DE LACO
    # ---------------------------------------------------------------
    dale.

    # ---------------------------------------------------------------
    # 17. FUNCAO DENTRO DE ESTRUTURA DE CONTROLE
    # ---------------------------------------------------------------
    sepa (VDD) {
        func int proibido() {
            receba 1.
        }.
    }.

    # ---------------------------------------------------------------
    # 18. PARAMETRO DUPLICADO
    # ---------------------------------------------------------------
    func int paramDup(int a. int a) {
        receba a.
    }.

    # ---------------------------------------------------------------
    # 19. ++ EM VETOR INTEIRO
    # ---------------------------------------------------------------
    bond int vetor[3].
    vetor ++.

    # ---------------------------------------------------------------
    # 20. ++ EM TIPO INVALIDO (STRING)
    # ---------------------------------------------------------------
    bglh txt s : "ola".
    s ++.

    # ---------------------------------------------------------------
    # 21. -- EM TIPO INVALIDO (STRING)
    # ---------------------------------------------------------------
    s --.

    # ---------------------------------------------------------------
    # 22. LEITURA DE VETOR INTEIRO
    # ---------------------------------------------------------------
    espia(vetor).

    # ---------------------------------------------------------------
    # 23. VARIAVEL SIMPLES INDEXADA COMO VETOR
    # ---------------------------------------------------------------
    bglh int normal : 10.
    normal[0] : 5.

    # ---------------------------------------------------------------
    # 24. INDICE DE VETOR DEVE SER INT
    # ---------------------------------------------------------------
    vetor["texto"] : 5.

    # ---------------------------------------------------------------
    # 25. OPERADOR + COM STRING (deveria usar &)
    # ---------------------------------------------------------------
    bglh int g : 5 + "texto".

    # ---------------------------------------------------------------
    # 26. OPERADOR e COM TIPOS NAO LOGICOS
    # ---------------------------------------------------------------
    bglh lgc l : 5 e 3.

    # ---------------------------------------------------------------
    # 27. OPERADOR nao COM TIPO NAO LOGICO
    # ---------------------------------------------------------------
    bglh lgc m : nao 5.

    # ---------------------------------------------------------------
    # 28. DIVISAO INTEIRA COM DECIMAIS
    # ---------------------------------------------------------------
    bglh qbd h : 5,0 // 3,0.

    # ---------------------------------------------------------------
    # 29. MODULO COM DECIMAIS
    # ---------------------------------------------------------------
    bglh qbd i : 5,0 % 3,0.

    # ---------------------------------------------------------------
    # 30. OPERADOR - UNARIO EM STRING
    # ---------------------------------------------------------------
    bglh txt j : -"texto".

    # ---------------------------------------------------------------
    # 31. CNJT COM TIPO INVALIDO
    # ---------------------------------------------------------------
    cnjt foo Invalido { A : 0. }.

    # ---------------------------------------------------------------
    # 32. CNJT DUPLICADO
    # ---------------------------------------------------------------
    cnjt int Dia { X : 0. }.
    cnjt int Dia { Y : 1. }.

    # ---------------------------------------------------------------
    # 33. ELEMENTO DUPLICADO NO CNJT
    # ---------------------------------------------------------------
    cnjt int Repetido { A : 0. A : 1. }.

    # ---------------------------------------------------------------
    # 34. ELEMENTO COM TIPO INCOMPATIVEL NO CNJT
    # ---------------------------------------------------------------
    cnjt int TiposErrados { A : "texto". }.

    # ---------------------------------------------------------------
    # 35. PEGUE (deuruim) COM TIPO QUE NAO E ERRO
    # ---------------------------------------------------------------
    sonha {
        bglh int z : 1.
    } deuruim (int err) {
        manda(err).
    }.

    # ---------------------------------------------------------------
    # 36. ACESSO A ELEMENTO INEXISTENTE DE CNJT
    # ---------------------------------------------------------------
    cnjt int Status { ATIVO : 1. INATIVO : 0. }.
    bglh int st : Status::INEXISTENTE.

    # ---------------------------------------------------------------
    # 37. CAMPO INEXISTENTE EM ERRO
    # ---------------------------------------------------------------
    sonha {
        bglh int w : 1 / 0.
    } deuruim (Erro err) {
        manda(err::campoInexistente).
    }.

    # ---------------------------------------------------------------
    # 38. VETOR NAO PODE SER USADO COMO EXPRESSAO
    # ---------------------------------------------------------------
    bglh int k : vetor.

    # ---------------------------------------------------------------
    # 39. TAMANHO SEM ARGUMENTO
    # ---------------------------------------------------------------
    bglh int t : tamanho().

    # ---------------------------------------------------------------
    # 40. INICIALIZACAO DE VETOR COM SLICE (so em slice assignment)
    # ---------------------------------------------------------------
    bond int fatia[3] : [1 ; 2 ; 3].

    # ---------------------------------------------------------------
    # 41. OPERADOR RELACIONAL COM TIPOS INCOMPATIVEIS
    # ---------------------------------------------------------------
    bglh lgc comp : "abc" > 5.

    # ---------------------------------------------------------------
    # 42. PANCADA (cada) COM EXPRESSAO QUE NAO E VETOR
    # ---------------------------------------------------------------
    bglh int escalar : 42.
    cada (bglh int elem em escalar) {
        manda(elem).
    }.

    # ---------------------------------------------------------------
    # 43. DIMENSOES MISTAS (estatica + dinamica)
    # ---------------------------------------------------------------
    bond int mista1[][3].
    bond int mista2[3][].

    # ---------------------------------------------------------------
    # 44. INDICE FORA DOS LIMITES (vetor 1D)
    # ---------------------------------------------------------------
    bond int limitado[5].
    limitado[5] : 99.

    # ---------------------------------------------------------------
    # 45. INDICE NEGATIVO
    # ---------------------------------------------------------------
    limitado[-1] : 99.

    # ---------------------------------------------------------------
    # 46. INDICE FORA DOS LIMITES (vetor 2D, 2a dimensao)
    # ---------------------------------------------------------------
    bond int matLimitada[2][3].
    matLimitada[0][3] : 99.

    # ---------------------------------------------------------------
    # 47. INDICE FORA DOS LIMITES (vetor 2D, 1a dimensao)
    # ---------------------------------------------------------------
    matLimitada[2][0] : 99.

    manda("Fim da demo de erros").
flw.
